{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["firefox-webext-browser"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
